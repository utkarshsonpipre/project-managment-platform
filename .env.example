# ---- Database (PostgreSQL) ----
DATABASE_URL="postgresql://pmp:pmp_password@localhost:5432/pmp?schema=public"

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- JWT auth ----
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ---- Object storage (S3 / MinIO) ----
# Locally these point at the MinIO container. In production, swap for real AWS S3 values.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="pmp-attachments"
S3_FORCE_PATH_STYLE="true"

# ---- Realtime (Socket.IO) ----
# Port the realtime server listens on locally (PaaS like Render inject PORT).
REALTIME_PORT="4001"
# The web app exposes this to the browser (via /api/realtime-info) so the client
# socket knows where to connect. Leave unset locally (defaults to localhost:4001).
# In production, set it to the realtime server's public URL, e.g.
#   REALTIME_PUBLIC_URL="https://pmp-realtime.onrender.com"
REALTIME_PUBLIC_URL="http://localhost:4001"

# ---- App ----
NODE_ENV="development"
APP_URL="http://localhost:3000"
